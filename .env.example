# ── Entorno ──
NODE_ENV=development

# ── Puerto (Vercel asigna el suyo, usar fallback local) ──
PORT=3000

# ── Supabase (PostgreSQL) ──
# Usar Transaction Pooler (puerto 6543) para Vercel serverless
DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres

# ── JWT ──
# Generar con: openssl rand -hex 64
JWT_SECRET=debes_cambiar_esto_en_produccion
JWT_EXPIRES_IN=86400

# ── CORS (separar múltiples orígenes con coma) ──
CORS_ORIGIN=http://localhost:4200

# ── Redis (opcional, Upstash para Vercel) ──
REDIS_URL=redis://default:password@xxxxx.upstash.io:6379
CACHE_TTL=60

# ── Admin interno (email que identifica al administrador) ──
ADMIN_EMAIL=admin@jaquealrey.com

# ── WhatsApp Cloud API (opcional, para notificar reservas) ──
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
ADMIN_WHATSAPP=

# ── MercadoPago (opcional, para pagos de reservas) ──
MP_ACCESS_TOKEN=
BASE_URL=http://localhost:3000
